{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "overseer",
  "model": "llama.cpp/gemma-4-e4b",
  "small_model": "llama.cpp/gemma-4-e4b",
  "share": "disabled",
  "enabled_providers": [
    "llama.cpp"
  ],
  "instructions": [
    "AGENTS.md",
    "journal/decisions.md"
  ],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local-dev-key"
      },
      "models": {
        "gemma-4-e4b": {
          "name": "Gemma 4 E4B (local)"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "deny"
    },
    "task": {
      "*": "deny"
    },
    "bash": {
      "*": "ask"
    },
    "edit": {
      "*": "ask"
    },
    "webfetch": "deny",
    "websearch": "deny"
  }
}
