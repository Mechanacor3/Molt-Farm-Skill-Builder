OPENAI_API_KEY=your_openai_key_here

# Subject/task model selection for:
# - ./molt skill-builder run ...
# - subject runs inside ./molt skill-builder eval-skill ...
# Supported providers: openai | openai_compatible | openai_responses
MOLT_SUBJECT_PROVIDER=openai
MOLT_SUBJECT_MODEL=gpt-5
MOLT_SUBJECT_BASE_URL=http://127.0.0.1:8080/v1
MOLT_SUBJECT_API_KEY=local-dev-key

# For the proxy-backed Responses experiment, switch to:
# MOLT_SUBJECT_PROVIDER=openai_responses
# MOLT_SUBJECT_BASE_URL=http://127.0.0.1:8000/v1

# Grader model selection for eval-skill grading.
# Supported providers: openai | openai_compatible | openai_responses
# Leave this on OpenAI for hybrid eval-skill grading.
MOLT_GRADER_PROVIDER=openai
MOLT_GRADER_MODEL=gpt-5
MOLT_GRADER_BASE_URL=http://127.0.0.1:8080/v1
MOLT_GRADER_API_KEY=local-dev-key

# Local llama.cpp Gemma 4 service defaults.
MOLT_GEMMA4_MODEL_FILE=gemma-4-e4b-q4.gguf
MOLT_GEMMA4_ALIAS=gemma-4-e4b
MOLT_GEMMA4_PORT=8080
MOLT_GEMMA4_CTX_SIZE=32768
MOLT_GEMMA4_PARALLEL=1
MOLT_GEMMA4_API_KEY=local-dev-key
